-- Aula Pratica --
SELECT * FROM countryinfo;

SELECT * FROM countryinfo WHERE _id = 'BRA';
-- Exibe conteudo por Chaves (propriedades, atributos) --
SELECT JSON_KEYS(doc) FROM countryinfo WHERE _id = 'BRA';
-- EXTRACT $. Exibe mais de uma chave interna do bloco JSON --
SELECT JSON_KEYS(doc,"$.geography") FROM countryinfo WHERE _id = 'BRA';
SELECT JSON_EXTRACT(doc,"$.government") FROM countryinfo WHERE _id = 'BRA';
SELECT JSON_EXTRACT(doc,"$.IndepYear") FROM countryinfo WHERE _id = 'BRA';
-- EXTRACT Exibe mais duas chave interna do bloco JSON --
SELECT DISTINCT JSON_EXTRACT(doc, "$.geography.Continent") AS continente FROM countryinfo ORDER BY continent DESC;
SELECT JSON_EXTRACT(doc,"$.geography.Continent") AS CONTINENTES FROM countryinfo WHERE _id = 'BRA';
SELECT JSON_EXTRACT(doc,"$.demographics.Population") AS POPULAÇÃO FROM countryinfo ;

SELECT JSON_EXTRACT(doc,"$.geography.Continent") AS CONTINENTE,(JSON_EXTRACT(doc,"$.demographics.Population")) AS POPULAÇÃO FROM countryinfo;



SELECT JSON_EXTRACT(doc,"$.demographics.Population") AS População_Total,(JSON_EXTRACT(doc,"$.government.monarchy")) AS Monarquias, 
(JSON_EXTRACT(doc,"$.demographics.LifeExpectancy")) Expectativa_Vida; 


